# gbrain-companion 環境變數範本
# 複製成 .env 後填入實際值

# gbrain HTTP API OTP（每日 UTC 00:00 輪換）
# 執行 `gbrain otp` 取得今日值
GBRAIN_OTP=

# gbrain API base URL（預設值已內建，無需修改）
GBRAIN_BASE_URL=https://gbrain-production-18fa.up.railway.app

# GeminiWebDriver 設定（T005+）
# Chrome profile 路徑（需已登入 Gemini Pro 的帳號）
# 不能使用正在運行 Chrome 的 profile（SingletonLock 衝突）
# macOS 範例: ~/Library/Application Support/Google/Chrome/Profile 2
GEMINI_PROFILE_DIR=

# Chrome 執行檔路徑（profile 若是 Google Chrome 格式則必填）
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE=

# Chrome for Testing 執行檔路徑（bench 用，比較速度差異）
# 安裝: npx @puppeteer/browsers install chrome@stable
# macOS arm64 範例（版本號依安裝結果調整）:
# ~/.cache/puppeteer/chrome/mac_arm-146.0.7680.153/chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing
CFT_EXECUTABLE=

# CfT 專用 profile 目錄（必須用 CfT binary 登入 Gemini Pro 後才能用於 bench）
# 與 GEMINI_PROFILE_DIR 分開，避免 Chrome v148 profile 被 CfT v146 開啟時版本衝突
# 建立: 用 CFT_EXECUTABLE 手動開啟一次並登入 Gemini，關閉後填入此路徑
# macOS 範例: ~/Library/Application Support/Google/Chrome/Profile-CfT
CFT_PROFILE_DIR=
